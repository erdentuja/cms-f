# Aurora CMS — tárhelybiztos szabályok.
# Szándékosan nincs "Options" direktíva (sok osztott tárhelyen 500-at okoz)
# és nincs "RewriteBase" sem: a relatív cél miatt almappából is működik.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Belső mappák és veszélyes fájlok védelme
    RewriteRule ^(app|storage)/ - [F,L]
    RewriteRule ^plugins/.*\.php$ - [F,L]
    RewriteRule ^uploads/.*\.(php[0-9]?|phtml|phar|cgi|pl|asp|aspx|jsp|sh|svg)$ - [F,L]

    # Létező fájlok kiszolgálása közvetlenül (a mappakérések a front controllerre
    # mennek, így mappalistázás sem fordulhat elő)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Minden más a front controlleren át
    RewriteRule ^ index.php [L]
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
